---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Sidebar from "@/components/common/Sidebar.astro";
import Preloader from "@/components/common/Preloader.astro";

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Mi Portfolio | 2026", 
	description = "Sitio web de portfolio personal creado con Astro",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<ClientRouter />
		
		<!-- Inline script to determine the theme instantly, preventing FOUC -->
		<script is:inline>
			const getThemePreference = () => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				return 'light'; // Default is dark
			};
			const theme = getThemePreference();
			document.documentElement.setAttribute('data-theme', theme);

			// Re-apply theme after page swap in View Transitions
			document.addEventListener('astro:after-swap', () => {
				const theme = getThemePreference();
				document.documentElement.setAttribute('data-theme', theme);
			});
		</script>

		<!-- SEO -->
		<title>{title}</title>
		<meta name="description" content={description} />
	</head>
	<body class="bg-bg-primary text-text-primary transition-colors duration-300">
		<Preloader />
		<div
			class="h-screen w-screen overflow-hidden flex flex-col md:flex-row bg-bg-primary text-text-primary font-sans selection:bg-text-primary selection:text-bg-primary transition-colors duration-500"
			id="portfolio-container"
		>
			<Sidebar />
			
			<!-- Mobile: Scrollable column. Desktop: Relative overlay system -->
			<main 
				class="flex-1 h-[calc(100vh-64px)] md:h-full overflow-y-auto md:overflow-hidden relative no-scrollbar scroll-smooth" 
				id="sections-wrapper"
			>
				<slot />
			</main>
		</div>
	</body>
</html>

<style>
	/* Make scrollbar match theme */
	html {
		scroll-behavior: smooth;
	}
	body::before {
		content: "";
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		background-image: url("/blob-haikei.svg");
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
		filter: blur(18px) saturate(180%);
		transform: scale(1.1);
	}
</style>
