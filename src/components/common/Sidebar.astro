---
import MobileHeader from "./sidebar/MobileHeader.astro";
import DesktopOverlay from "./sidebar/DesktopOverlay.astro";
import DesktopSidebar from "./sidebar/DesktopSidebar.astro";
---

<MobileHeader />
<DesktopOverlay />
<DesktopSidebar />

<script>
  import { gsap } from "gsap";

  function initSidebar() {
    // --- Desktop Menu Toggle (Overlay) ---
    const desktopMenuOverlay = document.getElementById("desktop-menu-overlay");
    const desktopMenuBtn = document.getElementById("menu-btn-desktop");
    const closeDesktopMenuBtn = document.getElementById(
      "close-desktop-menu-btn",
    );
    const floatingCloseBtn = document.getElementById("floating-close-btn");
    const desktopOverlayLinks = document.querySelectorAll(
      ".desktop-menu-overlay-link",
    );

    // Initialize overlay state using GSAP to avoid conflict with Tailwind classes
    if (desktopMenuOverlay) {
      desktopMenuOverlay.classList.remove(
        "-translate-x-full",
        "transition-transform",
        "duration-500",
        "ease-in-out"
      );
      gsap.set(desktopMenuOverlay, { xPercent: -100, visibility: "hidden" });
    }

    let menuTimeline: gsap.core.Timeline | null = null;

    function openDesktopMenu() {
      if (!desktopMenuOverlay) return;

      if (menuTimeline) menuTimeline.kill();

      menuTimeline = gsap.timeline();

      // Show overlay container and animate slide-in
      menuTimeline.set(desktopMenuOverlay, { visibility: "visible" });
      menuTimeline.to(desktopMenuOverlay, {
        xPercent: 0,
        duration: 0.6,
        ease: "power3.out"
      });

      // Target children elements for animation
      const logo = desktopMenuOverlay.querySelector("#desktop-menu-left a");
      const navLinks = desktopMenuOverlay.querySelectorAll(".desktop-menu-overlay-link");
      const controls = desktopMenuOverlay.querySelector("#desktop-menu-left .flex");
      const rightPanelItems = desktopMenuOverlay.querySelectorAll("#desktop-menu-right > div");

      // Reset nested elements to initial hidden state
      gsap.set(logo, { x: -30, opacity: 0 });
      gsap.set(navLinks, { x: -40, opacity: 0 });
      if (controls) gsap.set(controls, { y: 15, opacity: 0 });
      gsap.set(rightPanelItems, { y: 20, opacity: 0 });

      // Stagger items in
      menuTimeline.to(logo, {
        x: 0,
        opacity: 1,
        duration: 0.4,
        ease: "power2.out"
      }, "-=0.3");

      menuTimeline.to(navLinks, {
        x: 0,
        opacity: 1,
        duration: 0.4,
        stagger: 0.05,
        ease: "power2.out"
      }, "-=0.2");

      const rightItemsArray = Array.from(rightPanelItems);
      const bottomGroup = controls ? [controls, ...rightItemsArray] : rightItemsArray;

      menuTimeline.to(bottomGroup, {
        y: 0,
        opacity: 1,
        duration: 0.5,
        stagger: 0.05,
        ease: "power2.out"
      }, "-=0.3");
    }

    function closeDesktopMenu() {
      if (!desktopMenuOverlay) return;

      if (menuTimeline) menuTimeline.kill();

      menuTimeline = gsap.timeline({
        onComplete: () => {
          gsap.set(desktopMenuOverlay, { visibility: "hidden" });
        }
      });

      const logo = desktopMenuOverlay.querySelector("#desktop-menu-left a");
      const navLinks = desktopMenuOverlay.querySelectorAll(".desktop-menu-overlay-link");
      const controls = desktopMenuOverlay.querySelector("#desktop-menu-left .flex");
      const rightPanelItems = desktopMenuOverlay.querySelectorAll("#desktop-menu-right > div");

      const itemsArray = [
        ...Array.from(navLinks),
        logo,
        controls,
        ...Array.from(rightPanelItems)
      ].filter(Boolean);

      // Animate contents out quickly
      menuTimeline.to(itemsArray, {
        opacity: 0,
        duration: 0.25,
        stagger: 0.02,
        ease: "power2.in"
      });

      // Slide overlay container back
      menuTimeline.to(desktopMenuOverlay, {
        xPercent: -100,
        duration: 0.5,
        ease: "power3.inOut"
      }, "-=0.15");
    }

    if (desktopMenuBtn) {
      desktopMenuBtn.addEventListener("click", openDesktopMenu);
    }

    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    if (mobileMenuBtn) {
      mobileMenuBtn.addEventListener("click", openDesktopMenu);
    }

    if (closeDesktopMenuBtn) {
      closeDesktopMenuBtn.addEventListener("click", closeDesktopMenu);
    }

    if (floatingCloseBtn) {
      floatingCloseBtn.addEventListener("click", closeDesktopMenu);
    }

    if (desktopMenuOverlay) {
      desktopMenuOverlay.addEventListener("click", (e) => {
        if (e.target === desktopMenuOverlay) {
          closeDesktopMenu();
        }
      });
    }

    desktopOverlayLinks.forEach((link) => {
      link.addEventListener("click", () => {
        closeDesktopMenu();
      });
    });

    // --- Theme Switch Toggle Handler ---
    const htmlEl = document.documentElement;
    const desktopToggle = document.getElementById("theme-toggle-switch");
    const mobileToggle = document.getElementById("mobile-theme-toggle");
    const overlayToggle = document.getElementById(
      "overlay-theme-toggle-switch",
    );

    function toggleTheme() {
      const activeTheme = htmlEl.getAttribute("data-theme") || "dark";
      const nextTheme = activeTheme === "dark" ? "light" : "dark";

      htmlEl.setAttribute("data-theme", nextTheme);
      localStorage.setItem("theme", nextTheme);
    }

    if (desktopToggle) {
      desktopToggle.addEventListener("click", toggleTheme);
    }
    if (mobileToggle) {
      mobileToggle.addEventListener("click", toggleTheme);
    }
    if (overlayToggle) {
      overlayToggle.addEventListener("click", toggleTheme);
    }
  }

  // Initialize
  document.addEventListener("astro:page-load", initSidebar);
</script>
